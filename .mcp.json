{
  "mcpServers": {
    "irys-state": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "src.mcp_server"],
      "env": {
        "PYTHONPATH": "${CLAUDE_PROJECT_DIR:-.}"
      }
    },
    "blackboard": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PROJECT_DIR:-.}/packages/blackboard-mcp/dist/index.js"]
    }
  }
}
